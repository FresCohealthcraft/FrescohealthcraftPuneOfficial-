              <span className="text-[9px] font-bold text-stone-400 uppercase tracking-wider block">Active Users</span>
              <span className="text-sm font-sans font-black text-stone-800">
                {activeUsersCount} Active
              </span>
            </div>
            
            {/* Sparkline Path (Orange) */}
            <svg className="w-16 h-8 text-amber-500 overflow-visible" viewBox="0 0 100 30">
              <path
                d={activeUsersCount > 0 
                  ? "M0,18 Q20,4 40,20 T80,6 L100,16" 
                  : "M0,15 Q50,16 100,15"
                }
                fill="none"
                stroke="currentColor"
                strokeWidth="2.5"
                strokeLinecap="round"
                className="transition-all duration-500"
              />
            </svg>
          </div>

          {/* Growth Bar Chart */}
          <div className="bg-[#FAF9F5]/70 border border-stone-200/40 rounded-2xl p-3.5 flex items-center justify-between">
            <div className="space-y-0.5">
              <span className="text-[9px] font-bold text-stone-400 uppercase tracking-wider block">Weekly Growth</span>
              <span className="text-sm font-sans font-black text-stone-800">
                {growthValue}
              </span>
            </div>
            
            {/* Mini Bar Chart */}
            <div className="flex items-end space-x-1 h-8">
              {activeOrdersCount > 0 ? (
                <>
                  <div className="w-1.5 bg-[#289E68]/20 rounded-t-xs h-3.5 transition-all duration-500" />
                  <div className="w-1.5 bg-[#289E68]/40 rounded-t-xs h-5.5 transition-all duration-500" />
                  <div className="w-1.5 bg-[#289E68]/30 rounded-t-xs h-4.5 transition-all duration-500" />
                  <div className="w-1.5 bg-[#289E68]/60 rounded-t-xs h-7.5 transition-all duration-500" />
                  <div className="w-1.5 bg-[#289E68] rounded-t-xs h-8.5 transition-all duration-500" />
                </>
              ) : (
                <>
                  <div className="w-1.5 bg-[#289E68]/15 rounded-t-xs h-1 transition-all duration-500" />
                  <div className="w-1.5 bg-[#289E68]/15 rounded-t-xs h-1 transition-all duration-500" />
                  <div className="w-1.5 bg-[#289E68]/15 rounded-t-xs h-1 transition-all duration-500" />
                  <div className="w-1.5 bg-[#289E68]/15 rounded-t-xs h-1 transition-all duration-500" />
                  <div className="w-1.5 bg-[#289E68]/20 rounded-t-xs h-1.5 transition-all duration-500" />
                </>
              )}
            </div>
          </div>

        </div>

        {/* Popular List ranking */}
        <div className="space-y-2 pt-1 border-t border-stone-100 mt-1">
          {(() => {
            const displayItems = topItems.length > 0 ? topItems.slice(0, 3) : [
              { name: "Celery Cleanse Special", icon: "🥝", quantity: 18 },
              { name: "Immunity Booster juice", icon: "🛡️", quantity: 14 },
              { name: "Beta Blast Glow Smoothie", icon: "🍊", quantity: 11 },
            ];
            
            return displayItems.map((item, index) => (
              <div key={item.name} className="flex items-center justify-between text-[11px] hover:bg-stone-50 p-2 rounded-xl transition-all">
                <div className="flex items-center space-x-2">
                  <span className="text-stone-400 font-mono text-[10px]">0{index + 1}.</span>
                  <span className="text-base leading-none">{item.icon}</span>
                  <div className="flex items-center gap-1.5 min-w-0">
                    <span className="font-bold text-stone-700 truncate max-w-[120px] sm:max-w-xs">{item.name}</span>
                    {topItems.length === 0 && (
                      <span className="text-[8px] font-bold text-stone-300 uppercase shrink-0">Demo</span>
                    )}
                  </div>
                </div>
                <span className="text-[10px] font-black text-[#289E68] bg-[#E2F4E7] px-2.5 py-0.5 rounded-lg font-mono">
                  {item.quantity} Qty
                </span>
              </div>
            ));
          })()}
        </div>
      </div>
    </div>
  );
};

