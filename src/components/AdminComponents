// Circular Progress Component matching the "2/6" progress ring in the shared image
const CircularProgress = ({ completed, total }: { completed: number; total: number }) => {
  const safeTotal = total || 6;
  const percentage = (completed / safeTotal) * 100;
  const radius = 16;
  const circumference = 2 * Math.PI * radius;
  const strokeDashoffset = circumference - (percentage / 100) * circumference;

  return (
    <div className="relative w-12 h-12 flex items-center justify-center shrink-0">
      <svg className="w-12 h-12 transform -rotate-90">
        {/* Track circle */}
        <circle
          cx="24"
          cy="24"
          r={radius}
          className="text-stone-100"
          strokeWidth="3.5"
          stroke="currentColor"
          fill="transparent"
        />
        {/* Progress circle */}
        <circle
          cx="24"
          cy="24"
          r={radius}
          className="text-[#289E68]"
          strokeWidth="3.5"
          strokeDasharray={circumference}
          strokeDashoffset={strokeDashoffset}
          strokeLinecap="round"
          stroke="currentColor"
          fill="transparent"
        />
      </svg>
      <span className="absolute text-[10px] font-black text-[#1A1A1A] font-sans leading-none">
        {completed}/{safeTotal}
      </span>
    </div>
  );
};

